:80 {
	root * /srv
	encode gzip zstd

	@authCallback path /auth/callback*
	handle @authCallback {
		try_files {path} /index.html
		file_server
	}

	handle /auth/* {
		reverse_proxy schlussel:4000
	}

	handle {
		try_files {path} /index.html
		file_server
	}

	# Scoped to /assets/* (Vite's hashed build output), not by extension -
	# root-level static files like /favicon.svg are NOT content-hashed, so
	# caching them "immutable" for a year would hide any future change from
	# returning visitors for that long.
	@static path /assets/*
	header @static Cache-Control "public, immutable, max-age=31536000"
}
